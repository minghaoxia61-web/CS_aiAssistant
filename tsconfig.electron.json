{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "outDir": "dist-electron",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "noEmit": false,
    "declaration": false,
    "forceConsistentCasingInFileNames": false
  },
  "include": [
    "electron/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
