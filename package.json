{
  "name": "cs-assistant",
  "private": true,
  "version": "0.1.0",
  "description": "CS_Assistant - 智能复习助手桌面应用",
  "author": "CS_Assistant",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON \"vite\" \"npm run build:electron -- --watch\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "vite build && npm run build:electron",
    "preview": "vite preview",
    "lint": "eslint .",
    "check": "tsc -b --noEmit",
    "package": "npm run build && electron-builder --win",
    "package:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "jszip": "^3.10.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.8.0",
    "mermaid": "^11.15.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.30.4",
    "rehype-highlight": "^7.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.0.2",
    "uuid": "^9.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cs-assistant.tutor",
    "productName": "CS_Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "CS_Assistant-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CS_Assistant"
    }
  }
}
